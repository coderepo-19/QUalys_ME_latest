# ============================================================
# Qualys API Credentials & Settings
# ============================================================
QUALYS_USER=""
QUALYS_PASS=""

# Qualys API base URL (change for your region if needed)
# e.g. https://qualysapi.qg1.apps.qualys.in  (India)
#      https://qualysapi.qualys.com           (US)
QUALYS_BASE_URL="https://qualysapi.qg1.apps.qualys.in"

# Qualys Report Settings (get these from your Qualys portal)
QUALYS_TEMPLATE_ID=""
QUALYS_REPORT_TITLE="Cloud_Agent_Vuln_Report"
QUALYS_TAG_ID=""

# ============================================================
# ManageEngine ServiceDesk Plus (SDP) Settings
# ============================================================
SDP_DOMAIN="https://sdpondemand.manageengine.in"
SDP_PORTAL="itdesk"

# ============================================================
# Automation Settings (for automate_task.ps1)
# ============================================================
# Frequency: Daily, Weekly, Monthly
AUTO_RUN_FREQUENCY="Weekly"
# Time: HH:mm (24-hour format)
AUTO_RUN_TIME="09:00"
# Days: Comma-separated (e.g., Monday,Tuesday,Wednesday,Thursday,Friday) 
AUTO_RUN_DAYS="Friday"

# ============================================================
# Technician Assignment Settings (for Qualys_to_sdp.py)
# ============================================================
SDP_ASSIGNMENT_MODE="RoundRobin"
SDP_TECHNICIAN_LIST=""
