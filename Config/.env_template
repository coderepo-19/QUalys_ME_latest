# ============================================================
# CUSTOMER SETUP FILE - Fill in these values before running
# Rename this file to: .env
# ============================================================

# ---- Qualys API Credentials ----
QUALYS_USER="your_qualys_username"
QUALYS_PASS="your_qualys_password"

# ---- Qualys API Region URL ----
# India:  https://qualysapi.qg1.apps.qualys.in
# US:     https://qualysapi.qualys.com
# EU:     https://qualysapi.qualys.eu
QUALYS_BASE_URL="https://qualysapi.qg1.apps.qualys.in"

# ---- Qualys Report Settings ----
# Get these values from your Qualys Portal > Reports section
QUALYS_TEMPLATE_ID="your_template_id"
QUALYS_REPORT_TITLE="your_report_title"
QUALYS_TAG_ID="your_tag_id"

# ---- ManageEngine SDP Settings ----
# Your SDP Cloud URL (no trailing slash)
SDP_DOMAIN="https://sdpondemand.manageengine.in"
# Your SDP portal name (shown in the URL: /app/<portal>/)
SDP_PORTAL="itdesk"

# ============================================================
# Automation Settings (for automate_task.ps1)
# ============================================================
# 1. Frequency: Daily, Weekly, Monthly
AUTO_RUN_FREQUENCY="Weekly"

# 2. Time: HH:mm (24-hour format)
AUTO_RUN_TIME="09:00"

# 3. Days: (for Weekly or Monthly frequency only)
# For Weekly: Comma-separated days (Monday,Tuesday,Wednesday,Thursday,Friday,Saturday,Sunday)
#   Example Mon-Fri: "Monday,Tuesday,Wednesday,Thursday,Friday"
# For Monthly: Comma-separated numbers (1,2,3...31)
#   Example 1st & 15th: "1,15"
AUTO_RUN_DAYS="Monday,Tuesday,Wednesday,Thursday,Friday"

# ============================================================
# Technician Assignment Settings (for Qualys_to_sdp.py)
# ============================================================
# Mode: "RoundRobin", "Random", or "None"
SDP_ASSIGNMENT_MODE="RoundRobin"
# List: Comma-separated names or emails
# Example: "Technician A,Technician B,Technician C"
SDP_TECHNICIAN_LIST="Technician A,Technician B,Technician C"
